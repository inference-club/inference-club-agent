# inference-club-agent — service manifest
#
# Describes the hosts in your home network, each host's GPU, and the LLM
# services running on each host. The agent uploads this to inference.club
# on startup so your public profile at inference.club/<github_login>
# renders the same picture you describe here.
#
# Mount this file into the container at /etc/inference-club-agent/agent.yaml
# (see README docker-compose snippet). Edit it on the host and SIGHUP the
# container to reload:
#
#   docker kill -s HUP club-host
#
# Validate without restarting with:
#
#   docker exec club-host host-agent doctor

schema_version: 1

agent:
  name: brian-home              # label in the inference.club dashboard
  hostname: club-host-brian     # tailnet hostname (server may rewrite)
  listen_port: 443

hosts:
  - id: rig-01                  # short, unique within this manifest
    hostname: rig-01.local      # display only
    address: 192.168.1.10       # LAN IP, display only
    gpu:
      vendor: nvidia            # nvidia | amd | apple | intel
      model: RTX 4090
      vram_gb: 24
      count: 1
    notes: "main rig"
    services:
      - name: rtx-4090-vllm     # must be unique across the whole manifest
        engine: vllm            # vllm | lmstudio | ollama | sglang | llamacpp | tgi | other
        # type: llm             # llm (default) | stt | tts | image
        url: http://192.168.1.10:8000/v1
        # Per-model capabilities are DECLARED here — inference.club never guesses
        # them. `id` (served id, used for routing) is the only required field;
        # `hf` pools this model with the same model on other nodes and links its
        # HuggingFace page. Everything else is optional:
        #   name              human-friendly display name
        #   input_modalities  e.g. [text] or [text, image]; defaults from `type`
        #   output_modalities e.g. [text]; defaults from `type`
        #   features          model capabilities, e.g. [reasoning, tools]
        #   context_length    declared ceiling; the live-probed window wins
        #   quantization      e.g. fp8 / int4 (per-deployment)
        models:
          - id: qwen3-30b-a3b
            hf: Qwen/Qwen3-30B-A3B
            name: Qwen3 30B A3B
            features: [reasoning, tools]
            context_length: 32768
            quantization: fp8
          - id: mistral-small-3.1
            hf: mistralai/Mistral-Small-3.1-24B-Instruct
            input_modalities: [text, image]   # vision model
            features: [tools]
        command: >              # optional, free-form, for display
          vllm serve Qwen/Qwen3-30B-A3B
          --tensor-parallel-size 1 --max-model-len 32768

      - name: rtx-4090-asr      # a speech-to-text (ASR) service
        type: stt               # routes /v1/audio/transcriptions here
        engine: vllm
        url: http://192.168.1.10:8001/v1
        # Declare per-deployment capabilities. Add `timestamps` ONLY if this
        # server returns real word/segment timings via verbose_json — e.g.
        # Qwen3-ASR served with its ForcedAligner, or a Whisper server. A plain
        # `vllm serve Qwen/Qwen3-ASR-1.7B` does NOT, so leave it off there.
        # features: [timestamps]
        models:
          - id: Qwen/Qwen3-ASR-1.7B
            hf: Qwen/Qwen3-ASR-1.7B

      - name: rtx-4090-images   # an image-generation service
        type: image             # routes /v1/images/generations and /edits here
        engine: other
        url: http://192.168.1.10:8002/v1
        models:
          - id: my-image-model

      - name: rtx-4090-tts      # a text-to-speech service (NVIDIA Riva / Magpie)
        type: tts               # backend adapts /v1/audio/speech to this NIM
        engine: other
        url: http://192.168.1.10:9000/v1
        models:
          - id: magpie-tts-multilingual

      - name: rtx-4090-music    # a text-to-music service (ACE-Step)
        type: music             # routes /v1/music/generations here
        engine: other
        # ACE-Step's API is async — the agent submits the job (POST
        # /release_task), polls (POST /query_result), then downloads the
        # rendered audio (GET /v1/audio) and returns it in one reply. Use the
        # ACE-Step base URL (NO /v1 suffix); the model `id` selects the DiT
        # model and must match one ACE-Step has loaded.
        url: http://192.168.1.10:8015
        models:
          - id: acestep-v15-turbo

      - name: rtx-4090-video    # a text/image-to-video service (LTX-2)
        type: video             # routes /v1/videos/generations here
        engine: other
        # The agent forwards the JSON body to the LTX server's single POST
        # /generate endpoint and streams the rendered MP4 back. Use the LTX
        # base URL (NO /v1 suffix); it exposes /generate and /health directly.
        url: http://192.168.1.10:8023
        models:
          - id: ltx-2
            name: LTX-2 Video

  - id: mac-studio
    address: 192.168.1.20
    gpu:
      vendor: apple
      model: M2 Ultra
      vram_gb: 64               # unified memory
    services:
      - name: mac-studio-lmstudio
        engine: lmstudio
        url: http://192.168.1.20:1234/v1
        # Optional LOCAL-ONLY secret. If your backend requires an API key (e.g.
        # LM Studio started with one), put it here and the agent sends it as
        # `Authorization: Bearer <key>` on every proxied request. It is STRIPPED
        # from the manifest before upload, so it never reaches inference.club.
        # api_key: "sk-..."
        # No `models:` — server auto-discovers via GET /v1/models.
