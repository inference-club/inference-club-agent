      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "separate repo: Django API + Nuxt UI + Postgres\n\u2022 authenticates request, selects provider + model\n\u2022 mints ephemeral Tailscale auth keys (tag:club-host)\n\u2022 reverse-proxies /v1/* to the chosen agent over the tailnet",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "separate repo: Django API + Nuxt UI + Postgres\n\u2022 authenticates request, selects provider + model\n\u2022 mints ephemeral Tailscale auth keys (tag:club-host)\n\u2022 reverse-proxies /v1/* to the chosen agent over the tailnet",
      "lineHeight": 1.25
    },
