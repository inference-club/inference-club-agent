# Template for .env.dev (the local-dev agent's secrets, used by
# docker-compose.dev.yml). Copy to .env.dev and fill in your token:
#
#   cp .env.dev.example .env.dev
#
# Create the token on your *local* inference.club (dashboard → API token, or
# `manage.py drf_create_token <username>`). This is distinct from your prod
# token (which lives in .env).
INFERENCE_CLUB_API_KEY=
