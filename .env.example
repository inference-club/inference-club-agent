# Copy to .env (or pass directly to `docker run -e ...`).

# Required: account-level API key from https://inference.club/dashboard
INFERENCE_CLUB_API_KEY=

# Where the OpenAI-compatible LLM server lives on your LAN.
#   LM Studio:  http://host.docker.internal:1234/v1
#   Ollama:     http://host.docker.internal:11434/v1
#   vLLM:       http://host.docker.internal:8000/v1
LOCAL_LLM_URL=http://host.docker.internal:1234/v1

# Optional
INFERENCE_CLUB_URL=https://inference.club
AGENT_NAME=
AGENT_HOSTNAME=club-host
# AGENT_LISTEN_PORT=443
# TAILSCALE_LOGIN_SERVER=          # only for self-hosted Headscale
